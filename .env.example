# Z.AI
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL=glm-5.1
USE_REAL_ZAI=false

# Seedance 2.0
SEEDANCE_API_KEY=
# Optional comma-separated backup keys. The app tries these if the primary key hits quota/rate limits.
SEEDANCE_API_KEYS=
SEEDANCE_BASE_URL=https://seedanceapi.org/v2
SEEDANCE_MODEL=seedance-2.0-fast
SEEDANCE_DURATION=5
USE_REAL_VIDEO=false
ALLOW_MOCK_VIDEO_FALLBACK=true

# EasyRouter fallback
EASYROUTER_API_KEY=
EASYROUTER_BASE_URL=https://easyrouter.io/api/v1

# ImaRouter fallback
IMAROUTER_API_KEY=
IMAROUTER_BASE_URL=https://api.imarouter.ai/v1

# Butterbase
BUTTERBASE_URL=
BUTTERBASE_ANON_KEY=
BUTTERBASE_SERVICE_KEY=

# Local demo persistence writes to .data/butterbase-local.json
